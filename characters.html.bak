;base64,", "xingqiu": "data:image/svg+xml;base64,", "kokomi": "data:image/svg+xml;base64,", "nilou": "data:image/svg+xml;base64,", "mona": "data:image/svg+xml;base64,", "tartaglia": "data:image/svg+xml;base64,", "ayato": "data:image/svg+xml;base64,", "candace": "data:image/svg+xml;base64,", "barbara": "data:image/svg+xml;base64,", "mualani": "data:image/svg+xml;base64,", "hutao": "data:image/svg+xml;base64,", "xiangling": "data:image/svg+xml;base64,", "bennett": "data:image/svg+xml;base64,", "diluc": "data:image/svg+xml;base64,", "klee": "data:image/svg+xml;base64,", "yoimiya": "data:image/svg+xml;base64,", "lyney": "data:image/svg+xml;base64,", "dehya": "data:image/svg+xml;base64,", "arlecchino": "data:image/svg+xml;base64,", "amber": "data:image/svg+xml;base64,", "xinyan": "data:image/svg+xml;base64,", "yanfei": "data:image/svg+xml;base64,", "thoma": "data:image/svg+xml;base64,", "chevreuse": "data:image/svg+xml;base64,", "mavuika": "data:image/svg+xml;base64,", "ayaka": "data:image/svg+xml;base64,", "ganyu": "data:image/svg+xml;base64,", "shenhe": "data:image/svg+xml;base64,", "eula": "data:image/svg+xml;base64,", "chongyun": "data:image/svg+xml;base64,", "qiqi": "data:image/svg+xml;base64,", "diona": "data:image/svg+xml;base64,", "rosaria": "data:image/svg+xml;base64,", "layla": "data:image/svg+xml;base64,", "mika": "data:image/svg+xml;base64,", "freminet": "data:image/svg+xml;base64,", "wriothesley": "data:image/svg+xml;base64,", "charlotte": "data:image/svg+xml;base64,", "citlali": "data:image/svg+xml;base64,", "capitano": "data:image/svg+xml;base64,", "columbina": "data:image/svg+xml;base64,"};
function render(f){
var g=document.getElementById('cardGrid'),h='';
for(var id in C){var c=C[id];
if(f.el&&f.el!='all'&&c.element!=f.el)continue;
if(f.wp&&f.wp!='all'&&c.weapon!=f.wp)continue;
if(f.rar&&f.rar!='all'&&c.rarity!=parseInt(f.rar))continue;
if(f.q&&f.q!=''&&!c.name.toLowerCase().includes(f.q.toLowerCase()))continue;
var x={anemo:'#5dbf9a',geo:'#d4a84b',electro:'#b47bd4',dendro:'#7bc47b',hydro:'#4a9dd6',pyro:'#d9604a',cryo:'#7bc4d0'}[c.element]||'#d4a84b';
var s='';for(var i=0;i<5;i++)s+=i<c.rarity?'\u2605':'\u2606';
h+='<div class=card style=border-color:'+x+'44><a href=/character?char='+id+'>'+
'<div class=char-avatar>'+(A[id]?'<img src="'+A[id]+'">':'<span style=font-size:28px>?')+'</div>'+
'<div class=char-name>'+c.name+'</div><div class=char-rarity>'+s+'</div>'+
'<div><span style="padding:2px 8px;border-radius:10px;background:'+x+'22;color:'+x+';font-size:11px">'+c.element+'</span></div></a></div>';
}
g.innerHTML=h||'<div id=no-results style="grid-column:1/-1;text-align:center;padding:60px;color:#8b949e">No results</div>';
}
function f(){render({el:document.getElementById('elFilter').value,wp:document.getElementById('weaponFilter').value,rar:document.getElementById('rarityFilter').value,q:document.getElementById('searchInput').value})}
document.getElementById('elFilter').onchange=f;
document.getElementById('weaponFilter').onchange=f;
document.getElementById('rarityFilter').onchange=f;
document.getElementById('searchInput').oninput=f;
render({});
</script>
</body>
</html>