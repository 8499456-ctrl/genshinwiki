<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name=description content="Genshin Impact character builds, best weapons, artifacts, teams, and talent priorities for all 90+ characters.">
<title>Genshin Impact Characters — All Builds & Tier List</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
body{background:#0d1117;color:#e6e6e6}
.header{background:linear-gradient(135deg,#1a1a2e,#16213e);padding:24px;text-align:center}
.header h1{font-size:28px;margin-bottom:8px}
.header p{color:#8b949e;font-size:14px}
.filters{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;padding:20px 16px;background:#161b22;border-bottom:1px solid #30363d}
.filters select,.filters input{background:#0d1117;color:#e6e6e6;border:1px solid #30363d;border-radius:8px;padding:8px 14px;font-size:14px}
.filters input{flex:1;max-width:300px;min-width:180px}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:16px;padding:24px;max-width:1400px;margin:0 auto}
.card{background:#161b22;border:1px solid #30363d;border-radius:12px;padding:20px;text-align:center;transition:transform .15s,border-color .15s;position:relative}
.card:hover{transform:translateY(-4px);border-color:#d4a84b}
.card a{text-decoration:none;color:inherit;display:block}
.char-avatar{width:80px;height:80px;margin:0 auto 10px;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#1a1a2e}
.char-avatar img{width:70px;height:70px}
.char-name{font-size:16px;font-weight:700;margin-bottom:4px}
.char-rarity{letter-spacing:1px;font-size:14px;margin-bottom:6px}
.char-meta{font-size:12px;color:#8b949e}
.hidden{display:none!important}
#no-results{grid-column:1/-1;text-align:center;padding:60px;color:#8b949e}
</style>
</head>
<body>
<div class="header">
<a href=index.html style="color:#d4a84b;text-decoration:none">&larr; Home</a>
<h1>Genshin Impact Characters</h1>
<p>90 characters &middot; Best builds, teams &amp; materials</p>
</div>
<div class=filters>
<select id=elFilter><option value=all>All Elements</option><option value=anemo>Anemo</option><option value=geo>Geo</option><option value=electro>Electro</option><option value=dendro>Dendro</option><option value=hydro>Hydro</option><option value=pyro>Pyro</option><option value=cryo>Cryo</option></select>
<select id=weaponFilter><option value=all>All Weapons</option><option value=Sword>Sword</option><option value=Claymore>Claymore</option><option value=Polearm>Polearm</option><option value=Catalyst>Catalyst</option><option value=Bow>Bow</option></select>
<select id=rarityFilter><option value=all>All Rarity</option><option value=5>5&star;</option><option value=4>4&star;</option></select>
<input id=searchInput type=text placeholder="Search characters&hellip;">
</div>
<div id=cardGrid class=grid></div>
